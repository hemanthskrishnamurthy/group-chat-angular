{
  "name": "chat-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "ng": "ng",
    "dev": "node server/dev.mjs",
    "dev:client": "ng serve --host 0.0.0.0 --proxy-config proxy.conf.json",
    "dev:api": "node server/src/server.mjs",
    "build": "ng build",
    "start": "node server/src/server.mjs",
    "test:api": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand",
    "watch": "ng build --watch --configuration development",
    "preview": "ng serve --host 0.0.0.0"
  },
  "dependencies": {
    "@angular/animations": "^21.2.11",
    "@angular/common": "^21.2.11",
    "@angular/compiler": "^21.2.11",
    "@angular/core": "^21.2.11",
    "@angular/forms": "^21.2.11",
    "@angular/material": "^21.2.11",
    "@angular/platform-browser": "^21.2.11",
    "@angular/router": "^21.2.11",
    "bcryptjs": "^3.0.2",
    "compression": "^1.8.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.1",
    "helmet": "^8.1.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "lucide-angular": "^1.0.0",
    "rxjs": "~7.8.2",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "tslib": "^2.8.1",
    "winston": "^3.17.0",
    "zone.js": "~0.16.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.9",
    "@angular/cli": "^21.2.9",
    "@angular/compiler-cli": "^21.2.11",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.1.0",
    "cypress": "^14.5.2",
    "jest": "^30.0.5",
    "supertest": "^7.1.4",
    "typescript": "~5.9.3"
  },
  "type": "module"
}
